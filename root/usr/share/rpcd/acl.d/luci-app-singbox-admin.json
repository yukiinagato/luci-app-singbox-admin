{
    "luci-app-singbox-admin": {
        "description": "Grant access to sing-box admin pages",
        "read": {
            "cgi-io": [ "cbi" ],
            "luci": [ "admin/services/sing-box/*" ],
            "file": {
                "/etc/sing-box/*": [ "read" ],
                "/tmp/sing-box*": [ "read" ],
                "/etc/config/singbox": [ "read" ]
            },
            "ubus": {
                "service": [ "list" ]
            },
            "uci": [ "singbox" ]
        },
        "write": {
            "cgi-io": [ "cbi" ],
            "luci": [ "admin/services/sing-box/*" ],
            "file": {
                "/etc/sing-box/*": [ "write" ],
                "/tmp/sing-box*": [ "write" ],
                "/etc/config/singbox": [ "write" ]
            },
            "ubus": {
                "service": [ "start", "stop", "restart" ]
            },
            "uci": [ "singbox" ]
        }
    }
}
